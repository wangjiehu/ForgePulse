# ---------------------------------------------------------------------------
# Model provider (LLM advisory review layer)
# Do not commit real API tokens.
# ---------------------------------------------------------------------------
FORGEPULSE_MODEL_PROVIDER=offline
FORGEPULSE_MODEL_BASE_URL=
FORGEPULSE_MODEL_API_KEY=
FORGEPULSE_MODEL_NAME=
# Optional OpenAI-compatible gateway enables real LLM advisory review.
# The deterministic engine stays the source of truth; the LLM only reviews.
# FORGEPULSE_MODEL_PROVIDER=openai_compatible
# FORGEPULSE_MODEL_BASE_URL=http://localhost:8001/v1
# FORGEPULSE_MODEL_API_KEY=
# FORGEPULSE_MODEL_NAME=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
FORGEPULSE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Runtime security
# ---------------------------------------------------------------------------
# Comma-separated <key>:<role> entries. Role is viewer|engineer|admin.
# Unset/empty = OPEN MODE (no auth) for local dev only — NEVER use in production.
# Example: FORGEPULSE_API_KEYS=alice-key:admin,bob-key:viewer
FORGEPULSE_API_KEYS=
# Max requests per key per minute (default 60).
FORGEPULSE_RATE_LIMIT=60
# Audit log path (structured JSON lines).
FORGEPULSE_AUDIT_LOG=logs/audit.jsonl
# Log level (default INFO).
FORGEPULSE_LOG_LEVEL=INFO
